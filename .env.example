# =============================================================================
# Ventiqra environment configuration
# =============================================================================
# Copy this file to `.env` and adjust values for your environment.
#   cp .env.example .env
#
# NOTE: Never commit the real `.env` file. It is git-ignored.

# -----------------------------------------------------------------------------
# Global
# -----------------------------------------------------------------------------
ENV=development
COMPOSE_PROJECT_NAME=ventiqra

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ventiqra
POSTGRES_USER=ventiqra
POSTGRES_PASSWORD=changeme
# Connection string consumed by the backend (optional, overrides the above)
DATABASE_URL=postgres://ventiqra:changeme@postgres:5432/ventiqra?sslmode=disable

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# Backend (Go API)
# -----------------------------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8080
BACKEND_URL=http://localhost:8080
BACKEND_LOG_LEVEL=info
BACKEND_CORS_ORIGINS=http://localhost:3000

# JWT / auth (generate a strong random secret in production)
JWT_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# Simulation defaults
SIM_TICK_INTERVAL=1s
SIM_DEFAULT_SPEED=1

# -----------------------------------------------------------------------------
# Frontend (Next.js)
# -----------------------------------------------------------------------------
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=3000
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws

# -----------------------------------------------------------------------------
# Debug / feature flags
# -----------------------------------------------------------------------------
DEBUG=true
